{
  "name": "warm-light",

  "global": {
    "shell": {
      "_comment": "App shell and workspace background",
      "bg": "#f3f0eb"
    },
    "surface": {
      "_comment": "Cards, rows, cells, panels",
      "bg": "#faf7f2",
      "border": "#d1c7ba",
      "border-light": "#e7dfd5",
      "line": "#e4ddd3",
      "muted": "#8c8277"
    },
    "text": {
      "_comment": "Global text hierarchy",
      "primary": "#342f2a",
      "secondary": "#5c5650",
      "muted": "#8a8078",
      "darkest": "#27231f",
      "inverse": "#fff",
      "on-primary": "#fff8ef"
    }
  },

  "components": {
    "nav": {
      "_comment": "Side navigation bar",
      "bg": "#ebe5dc"
    },
    "input": {
      "_comment": "Input fields across the app",
      "focus": "#1a7f72"
    },
    "scrollbar": {
      "_comment": "Scrollbar thumb colors",
      "thumb": "#c8c1b6",
      "thumb-hover": "#a89f94"
    },
    "dropdown": {
      "_comment": "Dropdown menus (settings modal, etc.)",
      "focus": "#4a6fa5",
      "bg": "#fbfcfe",
      "border": "#c8d6e5"
    },
    "calendar": {
      "_comment": "Date picker / calendar popup",
      "today-ring": "#c4a33a",
      "gold-selected": "#c4a33a",
      "gold-header": "#c4a33a",
      "gold-text": "#5c4a1e",
      "gold-bg": "#fffef9",
      "gold-border": "#e0d5b0"
    },
    "context-menu": {
      "_comment": "Right-click context menu",
      "danger": "#c62f2f"
    }
  },

  "views": {
    "todo": {
      "_comment": "Todo list view",
      "datebar": {
        "_comment": "Date navigation bar at top",
        "today-marker": "#f5d78c",
        "selected-bg": "#e07b3c",
        "selected-text": "#fff8ef"
