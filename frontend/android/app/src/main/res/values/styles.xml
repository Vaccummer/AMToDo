<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#1a2820</item>
        <item name="colorPrimaryDark">#1a2820</item>
        <item name="colorAccent">#2a7fff</item>
        <item name="android:statusBarColor">#1a2820</item>
        <item name="android:navigationBarColor">#1a2820</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:statusBarColor">#1a2820</item>
        <item name="android:navigationBarColor">#1a2820</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">#1a2820</item>
        <item name="android:statusBarColor">#1a2820</item>
        <item name="android:navigationBarColor">#1a2820</item>
    </style>
</resources>
